{
  "name": "mini-chatgpt",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm:dev:server\" \"npm:dev:client\"",
    "dev:client": "vite --host 0.0.0.0",
    "dev:server": "tsx watch server/index.ts",
    "build": "vue-tsc -b && vite build",
    "preview": "vite preview --host 0.0.0.0"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.95.0",
    "@tailwindcss/vite": "^4.1.0",
    "@vitejs/plugin-vue": "^5.2.4",
    "cors": "^2.8.6",
    "dompurify": "^3.4.2",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "highlight.js": "^11.11.1",
    "markdown-it": "^14.1.1",
    "vite": "^6.3.0",
    "vue": "^3.5.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/markdown-it": "^14.1.2",
    "@types/node": "^25.6.0",
    "concurrently": "^9.2.1",
    "tsx": "^4.21.0",
    "typescript": "^5.8.0",
    "vue-tsc": "^2.2.10"
  }
}
